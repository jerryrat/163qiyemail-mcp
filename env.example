# 网易企业邮箱 MCP 配置

# SMTP/IMAP 服务器（根据数据中心选择）
# 杭州机房（推荐）
SMTP_HOST=smtphz.qiye.163.com
SMTP_PORT=994
SMTP_SECURE=true
IMAP_HOST=imaphz.qiye.163.com
IMAP_PORT=993
IMAP_SECURE=true

# 北京机房
# SMTP_HOST=smtp.qiye.163.com
# SMTP_PORT=994
# SMTP_SECURE=true
# IMAP_HOST=imap.qiye.163.com
# IMAP_PORT=993
# IMAP_SECURE=true

# 邮箱账号和密码（密码含特殊字符需用引号包裹）
SMTP_USER=your-email@your-domain.com
SMTP_PASS="your-password"

# 默认发件人
DEFAULT_FROM_EMAIL=your-email@your-domain.com

# Web API 主机（自动登录搜索用，一般不需要改）
WEB_HOST=mail.qiye.163.com
